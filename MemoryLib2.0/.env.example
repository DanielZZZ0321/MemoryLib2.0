# Server
PORT=3001
NODE_ENV=development

# 无 Docker 本地开发：设为 true 时使用 SQLite + 本地磁盘存储 + 进程内视频处理（无需 Postgres/Redis/MinIO）
MEMORIA_DEV_LITE=true
# 数据目录（可选，默认 ./data）
# MEMORIA_DATA_DIR=./data

# Database (PostgreSQL with pgvector) — Dev Lite 模式下可省略
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memoria

# Redis (BullMQ) — Dev Lite 模式下可省略
# REDIS_URL=redis://localhost:6379

# Storage (MinIO / S3) — Dev Lite 模式下可省略（文件写入 ./data/storage）
# STORAGE_ENDPOINT=localhost
# STORAGE_PORT=9000
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_BUCKET=memoria
# STORAGE_USE_SSL=false

# LLM：OpenAI 兼容 /v1/chat/completions（推荐 AIHubMix，见 https://docs.aihubmix.com/cn ）
# 优先级：AIHUBMIX_* > OPENAI_* > GEMINI_*（旧名，需 KEY+BASE 同时配置）
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_MODEL=gemini-2.5-flash

# 直连 OpenAI（未配置 AIHUBMIX_API_KEY 时生效）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 兼容旧 .env 命名（二者须同时存在才会启用）
# GEMINI_API_KEY=
# GEMINI_API_BASE_URL=https://aihubmix.com/v1
# GEMINI_MODEL=gemini-2.5-flash

# Video Processing（转码由子进程调用本机 ffmpeg，见 server/src/services/ffmpeg/）
VIDEO_MAX_SIZE_MB=500
VIDEO_COMPRESSION_PRESET=fast
VIDEO_OUTPUT_RESOLUTION=720p
VIDEO_CRF=23
# 无本机 ffmpeg 时设为 true：跳过转码，仅用原片跑 VLM 抽帧与时间线（生产建议 false 并安装 ffmpeg）
# VIDEO_SKIP_TRANSCODE=true
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
# FFPROBE_PATH=C:\path\to\ffprobe.exe

# 视频时间线（VLM 多模态）：均匀抽帧数量上限；可选单独指定模型（默认沿用 AIHUBMIX_MODEL）
# VIDEO_TIMELINE_MAX_FRAMES=8
# VIDEO_TIMELINE_VLM_MODEL=gemini-2.5-flash

# 上传照片后自动 VLM 提取标题/摘要/标签写入 raw metadata（需 LLM；设为 false 可关闭）
# AUTO_MEDIA_ENRICH=true
# MEDIA_ENRICH_MODEL=gemini-2.5-flash

# Frontend (client/.env.development)
# VITE_API_BASE_URL=http://localhost:3001/api
