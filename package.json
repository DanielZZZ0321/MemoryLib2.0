{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript frontend + Express backend with data server integration",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:memory-core": "cd memory-core && .venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web-next": "npm run dev --prefix web-next",
    "build": "npm run build --workspaces",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "serve": "npm run build && npm run start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}
