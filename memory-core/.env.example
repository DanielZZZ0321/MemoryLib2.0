# CORS for Next.js dev server
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# 未创建本文件时也会自动读取 ../backend/.env（与 Express 共用 AIHUBMIX_API_KEY 等）
# 若同时存在本文件，此处变量会覆盖 backend/.env

# OpenAI-compatible chat（AiHubMix：可只设 AIHUBMIX_BASE_URL=https://aihubmix.com，会自动补 /v1）
# OPENAI_API_KEY=
# AIHUBMIX_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_APP_CODE=
# LLM_BASE_URL=https://aihubmix.com/v1

# Embeddings / Whisper
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# WHISPER_MODEL=base
